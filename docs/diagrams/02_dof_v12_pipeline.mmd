    style SUP_ESCALATE fill:#FF9800,color:#fff,stroke:#E65100
    style Z3 fill:#00BCD4,color:#fff,stroke:#00838F
    style REDBLUE fill:#EF5350,color:#fff,stroke:#C62828
    style RB_UNRESOLVED fill:#EF5350,color:#fff,stroke:#C62828
