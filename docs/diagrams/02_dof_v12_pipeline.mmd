    style CONST_BLOCK fill:#4CAF50,color:#fff,stroke:#2E7D32
    style AST fill:#4CAF50,color:#fff,stroke:#2E7D32
    style AST_FAIL fill:#4CAF50,color:#fff,stroke:#2E7D32
    style SUPERVISOR fill:#FF9800,color:#fff,stroke:#E65100
